<Window x:Class="LocalRouteMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Route Monitor" Height="680" Width="1240"
        MinHeight="620" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FB">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Local Route Monitor"/>
                <TextBlock Foreground="#5B667A" FontSize="11" Text="检查 TeamViewer / 飞书 / 百度网盘 是否走本地中国出口，而不是 VPN 默认路由"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="立即检测" Width="96" Height="30" Margin="0,0,6,0" Click="RefreshButton_Click"/>
                <Button Content="刷新路由" Width="96" Height="30" Margin="0,0,8,0" Click="RefreshRoutesButton_Click"/>
                <TextBlock VerticalAlignment="Center" Foreground="#5B667A" FontSize="11" Text="{Binding LastChecked}"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
            <TabItem Header="总览">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" CanContentScroll="True">
                    <StackPanel Margin="0,8,0,0">
                        <Border Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="状态总览" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Margin="0,4,0,0" Foreground="#344054" FontSize="11" Text="{Binding OverallSummary}" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,3,0,0" Foreground="#7A5C00" FontSize="11" Text="{Binding RefreshSummary}" TextWrapping="Wrap"/>
                                <Border Margin="0,8,0,0" Background="{Binding AdminModeBackground}" BorderBrush="{Binding AdminModeForeground}" BorderThickness="1" CornerRadius="4" Padding="8">
                                    <TextBlock Foreground="{Binding AdminModeForeground}" FontSize="11" FontWeight="SemiBold" Text="{Binding AdminModeSummary}" TextWrapping="Wrap"/>
                                </Border>

                                <Border Margin="0,10,0,0" Background="#F8FAFC" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="6" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RefreshResultTitle}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,4,0,0" Foreground="#344054" FontSize="11" Text="{Binding RefreshResultSummary}" TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,6,0,0" Foreground="#B42318" FontSize="11" FontWeight="SemiBold" Text="{Binding RefreshResultUnmatched}" TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,3,0,0" Foreground="#177245" FontSize="11" FontWeight="SemiBold" Text="{Binding RefreshResultStable}" TextWrapping="Wrap"/>
                                        <Border Margin="0,8,0,0" Background="#EEF4FF" BorderBrush="#98A2FF" BorderThickness="1" CornerRadius="4" Padding="8">
                                            <TextBlock Foreground="#3538CD" FontSize="11" FontWeight="SemiBold" Text="{Binding RefreshDeltaSummary}" TextWrapping="Wrap"/>
                                        </Border>
                                        <Border Margin="0,8,0,0" Background="#FFF8E7" BorderBrush="#F0C75E" BorderThickness="1" CornerRadius="4" Padding="8">
                                            <TextBlock Foreground="#7A5C00" FontSize="11" Text="{Binding RouteRefreshDetail}" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="6" Padding="8">
                            <StackPanel>
                                <TextBlock Text="VPN 状态" FontSize="14" FontWeight="SemiBold"/>
                                <UniformGrid Margin="0,4,0,0" Columns="2">
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="当前 VPN"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.CurrentVpn}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="默认路由"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.DefaultRoute}" TextWrapping="Wrap"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="VPN 公网 IP"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.VpnPublicIp}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="VPN 综合地区"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.VpnPublicCountry}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="非 VPN 公网 IP"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.LocalPublicIp}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="非 VPN 综合地区"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.LocalPublicCountry}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="当前公网 IP"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.PublicIp}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="当前综合地区"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.PublicCountry}"/></Grid>
                                    <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="结论"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding Vpn.Summary}" TextWrapping="Wrap"/></Grid>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="网络测速（国内直连 / 海外 VPN）" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding SpeedItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,6,0,0" Background="#F9FBFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="6" Padding="9">
                                                <StackPanel>
                                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name}"/>
                                                    <TextBlock Foreground="#5B667A" FontSize="12" Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                    <UniformGrid Margin="0,6,0,0" Columns="2">
                                                        <Grid Margin="0,0,10,5"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="12" Text="路径类型"/><TextBlock Grid.Column="1" FontSize="12" Text="{Binding PathType}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="测速区域"/><TextBlock Grid.Column="1" Text="{Binding TargetRegion}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="公网 IP"/><TextBlock Grid.Column="1" Text="{Binding PublicIp}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="综合地区"/><TextBlock Grid.Column="1" Text="{Binding PublicCountry}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="延迟"/><TextBlock Grid.Column="1" Text="{Binding Latency}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="TCP 443"/><TextBlock Grid.Column="1" Text="{Binding Tcp443}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="下载"/><TextBlock Grid.Column="1" Text="{Binding DownloadEstimate}"/></Grid>
                                                        <Grid Margin="0,0,12,8"><Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" Text="上传"/><TextBlock Grid.Column="1" Text="{Binding UploadEstimate}"/></Grid>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,8" Background="#FFFFFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="VPN 稳定性探测" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding VpnProbeItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Background="#F9FBFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="8" Padding="12">
                                                <UniformGrid Columns="5">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Target}"/>
                                                    <TextBlock Text="{Binding Protocol}"/>
                                                    <TextBlock Text="{Binding Result}"/>
                                                    <TextBlock Text="{Binding Latency}"/>
                                                    <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"/>
                                                </UniformGrid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="应用出口监控">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" CanContentScroll="True">
                    <Border Margin="0,8,0,0" Background="#FFFFFF" BorderBrush="#D8E0EF" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="应用出口监控" FontSize="14" FontWeight="SemiBold"/>
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Background="{Binding CardBackground}" BorderBrush="{Binding CardAccentBrush}" BorderThickness="1.5" CornerRadius="6" Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Left">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding AppName}"/>
                                                        <TextBlock Foreground="#5B667A" FontSize="11" Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border DockPanel.Dock="Right" Background="{Binding StatusBadgeBackground}" CornerRadius="5" Padding="8,3">
                                                        <TextBlock FontWeight="SemiBold" FontSize="11" Foreground="{Binding StatusBadgeForeground}" Text="{Binding Status}"/>
                                                    </Border>
                                                </DockPanel>

                                                <StackPanel Grid.Row="2">
                                                    <UniformGrid Columns="5">
                                                        <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="本机出口"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding SourceAddress}"/></Grid>
                                                        <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="主远端"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding RemoteAddress}"/></Grid>
                                                        <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="命中覆盖"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding RouteCoverage}"/></Grid>
                                                        <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="86"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="命中路由"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding RouteMatched}"/></Grid>
                                                        <Border Grid.ColumnSpan="2" Margin="0,0,8,4" Background="{Binding UnmatchedBackground}" BorderBrush="{Binding UnmatchedForeground}" BorderThickness="1" CornerRadius="4" Padding="6,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                <TextBlock Foreground="{Binding UnmatchedForeground}" FontSize="11" FontWeight="SemiBold" Text="{Binding UnmatchedLabel}"/>
                                                                <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Foreground="{Binding UnmatchedForeground}" Text="{Binding UnmatchedRemoteIps}" TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </UniformGrid>

                                                    <TextBlock Margin="0,4,0,2" FontSize="11" FontWeight="SemiBold" Foreground="{Binding RepairHintForeground}" Text="{Binding RepairHint}" TextWrapping="Wrap"/>

                                                    <Border Margin="0,2,0,2" Background="{Binding AdviceBackground}" BorderBrush="{Binding AdviceForeground}" BorderThickness="1" CornerRadius="4" Padding="6">
                                                        <StackPanel>
                                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{Binding AdviceForeground}" Text="{Binding RecommendedActionTitle}"/>
                                                            <TextBlock Margin="0,3,0,0" FontSize="11" FontWeight="SemiBold" Foreground="{Binding AdviceForeground}" Text="{Binding UnmatchedLabel}" TextWrapping="Wrap"/>
                                                            <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{Binding AdviceForeground}" Text="{Binding RefreshAdvice}" TextWrapping="Wrap"/>
                                                            <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{Binding AdviceForeground}" Text="{Binding ManualRouteAdvice}" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Expander Margin="0,2,0,0" Header="详细信息" FontSize="11">
                                                        <UniformGrid Margin="0,4,0,0" Columns="4">
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="进程数"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding ProcessCount}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="连接状态"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding ConnectionStates}" TextWrapping="Wrap"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="远端端口"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding RemotePort}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="网关"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding Gateway}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="接口"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding InterfaceAlias}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="延迟"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding Latency}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="TCP 检测"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding TcpReachable}"/></Grid>
                                                            <Grid Margin="0,0,8,4"><Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Foreground="#667085" FontSize="11" Text="远端 IP 列表"/><TextBlock Grid.Column="1" FontSize="11" Text="{Binding DetectedRemoteIps}" TextWrapping="Wrap"/></Grid>
                                                        </UniformGrid>
                                                    </Expander>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
